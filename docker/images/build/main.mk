# ========== Variable calculation ==========

# Don't be verbose by default.
Q?=@

# Input rules.
MKS:=$(shell find . -path ./build -prune -o -path '*.dockerbuild' -prune -o -path '*.rootfs.*' -prune -o -name "*.mk" -print)
MKS:=$(MKS:./%=%)
# Fake images. These are timestamp files to indicate when the images are built.
IMGS:=$(MKS:%.mk=%)
# Rules to remove docker images.
IMGS_CLEAN_RULES:=$(IMGS:%=_rmi_%)
# File prefix which shows the dependency.
DEP:=images-dependency


# ========== Macros definitions ===========

# Macro to expand shell scripts which returns true if we should skip the generation.
# Return true if target is a 32bit image and our CPU doesn't support 32bit.
# Note : It might be the case Makefile -> sh -> script(bash). In this case, bash
#        functions will be disabled due to sh in the middle. So import the helper
#        functions again.
# $1 : target
define SKIP_GENERATION
(false)
endef

# Macro to generate fake image file with the timestamp the same as the image.
# $1 : image_name
define GENERATE_TIMESTAMP
$(Q)echo ==== Generating fake image file : $1
$(Q)$(call SKIP_GENERATION,$1) || ./build/gen-timestamp.sh $1
endef

# Macro to generate docker images.
# $1 : target
# $2 : base
# $3 : additional docker build parameters -- optional
define GENERATE_REAL_IMAGE
$(Q)echo ==== Generating docker image : $1
$(Q)$(call SKIP_GENERATION,$1) || ./build/gen-image.sh $2 $1 $3
$(Q)touch $1
endef

# Macro to generate docker images when RULE is not defined.
# $1 : image_name
define GENERATE_IMAGE_DEFAULT
$(Q)$(call SKIP_GENERATION,$1) || $(MAKE) $1 RULE=build/image.mk
endef

# Macro to generate image dependency file.
# $1 : target
# $2 : base
define GENERATE_IMAGE_DEPENDENCY
$(Q)echo ==== Generating image dependency: $1
$(Q)$(call SKIP_GENERATION,$1) || echo '"$2"->"$1"' >> $(DEP).dot
endef

# Macro to get image name.
# Our build system assumes that the image name should always match the file name.
# This macro can be used to get the image name from filename to avoid conflicts.
define GET_IMAGE_NAME_FROM_FILE
$(patsubst %.mk,%,$(lastword $(MAKEFILE_LIST)))
endef

# ========== Build rules start from here ==========

help:
	$(Q)echo
	$(Q)echo "Make targets :"
	$(Q)echo "  all        - Build all images"
	$(Q)echo "  dep        - Create a dot file which shows the images dependency"
	$(Q)echo "  clean      - Remove all fake images"
	$(Q)echo "  untagclean - Remove all untagged docker images"
	$(Q)echo "  distclean  - clean + untagclean + Remove all docker images generated by the makefile"
	$(Q)echo
	$(Q)echo "Available docker images :"
	$(Q)echo "  $(IMGS)"
	$(Q)echo
	$(Q)echo "Use 'Q=' to get verbose output, for example :"
	$(Q)echo "  make clean Q="
	$(Q)echo
	$(Q)echo "For further info : \$$CI_TOP/docs/docker.md"
	$(Q)echo

all: $(IMGS)

# Rules to build dependency graph.
dep: $(DEP) $(DEP).txt $(DEP).png
$(DEP): $(DEP).dot
	$(Q) - graph-easy --as=ascii images-dependency.dot
$(DEP).txt: $(DEP).dot
	$(Q) - graph-easy --as=ascii images-dependency.dot > $@
$(DEP).png: $(DEP).dot
	$(Q)dot -Tpng -o$@ $<
$(DEP).dot: $(MKS)
	$(Q)echo "digraph Images { rankdir=LR; node[width=0 height=0 shape=record];" > $@
	$(Q)$(MAKE) -j 1 $(MAKECMDGOALS:dep=all) RULE=build/dependency.mk
	$(Q)echo "}" >> $@

# '::' is used, so that we can define additional clean rules in .mk files.
clean::
	$(Q)rm -fr $(IMGS) $(IMGS:%=%.dockerfile.generated) $(IMGS:%=%.dockerbuild) $(IMGS:%=%.patch) $(DEP).*

untagclean:
	$(Q)if [ ! -z "$$(docker images | grep '<none>' | awk '{print $$3}')" ] ; then docker rmi $$(docker images | grep '<none>' | awk '{print $$3}') ; fi

distclean: clean untagclean $(IMGS_CLEAN_RULES)

$(IMGS_CLEAN_RULES) : _rmi_% :
	$(Q)if [ "$(shell docker images -q $*)" != "" ] ; then docker rmi $* ; fi

.PHONY: help all dep $(DEP) $(DEP).dot clean untagclean distclean $(IMGS_CLEAN_RULES)

# ========== Additional includes ==========

# Build rules for image generation.
RULE?=build/default.mk
include $(RULE)

# Image dependencies.
include $(MKS)

